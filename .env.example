# ── The Odds API ─────────────────────────────────────────────────────────────
# Get your key at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Sport key: "upcoming" shows all upcoming games across all sports (default).
# Set to a specific key like "icehockey_nhl" for NHL-only odds.
ODDS_API_SPORT=upcoming

# Bookmaker region: us | uk | eu | au
ODDS_API_REGION=us

# Seconds to cache odds responses before re-fetching
ODDS_CACHE_TTL=300

# ── Upstash Redis (optional, for production caching) ─────────────────────────
# Leave empty to fall back to in-memory cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
CRON_TIMEZONE=America/New_York
CRON_SECRET=

# ── Python ML pipeline (separate from Next.js) ───────────────────────────────
ML_ODDS_DB_URL=sqlite:///ml_odds.db
